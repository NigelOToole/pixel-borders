{
  "name": "pixel-borders",
  "homepage": "https://nigelotoole.github.io/pixel-borders/",
  "author": "Nigel O Toole <pure@purestructure.com> (http://www.purestructure.com)",
  "description": "Add pixelated borders to HTML elements and customize with different sizes, colours and styles.",
  "keywords": [
    "sass",
    "postcss",
    "mixin",
    "pixel",
    "pixelated",
    "borders",
    "css"
  ],
  "main": "src/styles/pixel-borders.css",
  "version": "2.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NigelOToole/pixel-borders.git"
  },
  "bugs": {
    "url": "https://github.com/NigelOToole/pixel-borders/issues"
  },
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@11ty/eleventy-dev-server": "^2.0.8",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.9",
    "postcss-advanced-variables": "^5.0.0",
    "postcss-cli": "^11.0.1",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.2.0",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0"
  },
  "scripts": {
    "clean": "rimraf src/**/*.map",
    "dev": "cross-env NODE_ENV=development && concurrently \"npm:dev:*\"",
    "dev:server": "npx @11ty/eleventy-dev-server --dir=src",
    "dev:styles": "postcss src/styles/site/main.css --dir src/styles --watch",
    "dev:sass": "sass src/styles/pixel-borders/sass/pixel-borders.scss src/styles/pixel-borders.css --watch",
    "postcss": "postcss src/styles/pixel-borders/postcss/pixel-borders.css --o src/styles/pixel-borders.css --watch",
    "build": "npm run clean && cross-env NODE_ENV=production concurrently \"npm:build:*\"",
    "build:styles": "postcss src/styles/site/main.css src/styles/pixel-borders/pixel-borders.css --dir src/styles",
    "publish:npm": "npm run build && npm publish"
  }
}
